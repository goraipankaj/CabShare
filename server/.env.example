# SERVER
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# DATABASE
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/cabshare

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CLOUDINARY (document / avatar uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# NODEMAILER (email verification / reset password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CabShare <no-reply@cabshare.app>"

# TWILIO (OTP / SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# FIREBASE (push notifications) - paste service account JSON as a single line
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# RAZORPAY (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# GOOGLE MAPS
GOOGLE_MAPS_API_KEY=

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
