# Base URL for the backend API (leave as /api to use the Vite dev proxy to localhost:5000)
VITE_API_BASE_URL=/api

# Socket.IO server URL
VITE_SOCKET_URL=http://localhost:5000

# Google Maps JavaScript API key (for autocomplete widgets / map rendering in the browser)
VITE_GOOGLE_MAPS_API_KEY=

# Razorpay public key id (safe to expose client-side)
VITE_RAZORPAY_KEY_ID=
